# ---- Backend (server/) ----
# API key TMDB (v3): registrati gratis su https://www.themoviedb.org/settings/api
# Vive SOLO sul server: il client passa dal proxy /api/tmdb.
TMDB_API_KEY=your_tmdb_api_key_here

# Ore di cache server-side delle risposte TMDB (default 24)
TMDB_CACHE_HOURS=24

# Porta del backend (default 3001; le piattaforme PaaS la impostano da sole)
PORT=3001

# Directory del database SQLite (default ./data — in produzione un disco persistente)
DATA_DIR=./data

# ---- Frontend (Vite, prefisso VITE_) ----
# Base URL delle API. Default "/api": frontend e backend sullo stesso dominio.
# Impostala solo se il frontend è deployato separatamente (es. https://api.tuodominio.com/api)
# VITE_API_URL=/api
